# Complex assembly for MM/GBSA
# Generated by rescore.parameterization.complex

# Load force fields
source leaprc.protein.ff14SB
source leaprc.gaff2

# Load ligand parameters
loadamberparams ../ligand/ligand.frcmod

# Load protein from PDB (coordinates from inpcrd conversion)
protein = loadpdb protein.pdb

# Load ligand with coordinates from MOL2
ligand = loadmol2 ../ligand/ligand.mol2

# Combine protein + ligand
complex = combine {protein ligand}

# Check structure
check complex

# Save complex topology
saveamberparm complex complex.prmtop complex.inpcrd

# Exit
quit
