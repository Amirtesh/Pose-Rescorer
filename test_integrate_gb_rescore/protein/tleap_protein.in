# tleap script for protein preparation
# Force field: ff14SB
# Generated by rescore
# Input: test_receptor_amber.pdb

# Load force field
source leaprc.protein.ff14SB

# Load protein PDB
protein = loadpdb test_receptor_amber.pdb

# Check for issues
check protein

# Save topology and coordinates
saveamberparm protein protein.prmtop protein.inpcrd

# Quit
quit
